# Optional: set this only if you created a non-default Firestore DB ID.
# If your Firestore database ID is '(default)', leave this unset.
# VITE_FIRESTORE_DATABASE_ID=officiating-marketplace-db

# Optional: set a non-default callable functions region.
# VITE_FIREBASE_FUNCTIONS_REGION=us-central1

# Optional: use the local Firebase Functions emulator during development.
# VITE_USE_FUNCTIONS_EMULATOR=true
# VITE_FUNCTIONS_EMULATOR_HOST=127.0.0.1
# VITE_FUNCTIONS_EMULATOR_PORT=5001

# Optional: enables Google Places autocomplete on the Post a Game location field.
# VITE_GOOGLE_MAPS_API_KEY=your_google_maps_api_key
