rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function ownProfile() {
      return get(/databases/$(database)/documents/userProfiles/$(request.auth.uid));
    }

    function hasRole(role) {
      return signedIn() && ownProfile().data.role == role;
    }

    function canManageGames() {
      return hasRole("assignor") || hasRole("school");
    }

    function canEvaluateGames() {
      return hasRole("evaluator");
    }

    function ownsGame(gameId) {
      return signedIn()
        && exists(/databases/$(database)/documents/games/$(gameId))
        && get(/databases/$(database)/documents/games/$(gameId)).data.createdByUid == request.auth.uid;
    }

    function gameExists(gameId) {
      return exists(/databases/$(database)/documents/games/$(gameId));
    }

    function crewExists(crewId) {
      return exists(/databases/$(database)/documents/crews/$(crewId));
    }

    function requesterIsCrewChief(crewId) {
      return crewExists(crewId)
        && (
          (
            get(/databases/$(database)/documents/crews/$(crewId)).data.keys().hasAny(["crewChiefUid"])
            && get(/databases/$(database)/documents/crews/$(crewId)).data.crewChiefUid == request.auth.uid
          )
          || (
            !get(/databases/$(database)/documents/crews/$(crewId)).data.keys().hasAny(["crewChiefUid"])
            && get(/databases/$(database)/documents/crews/$(crewId)).data.createdByUid == request.auth.uid
          )
        );
    }

    function gameLevelIsVarsity(gameId) {
      return gameExists(gameId)
        && get(/databases/$(database)/documents/games/$(gameId)).data.level == "Varsity";
    }

    function gameOpenForBidding(gameId) {
      return gameExists(gameId)
        && get(/databases/$(database)/documents/games/$(gameId)).data.status == "open"
        && (
          !get(/databases/$(database)/documents/games/$(gameId)).data.keys().hasAny(["mode"])
          || get(/databases/$(database)/documents/games/$(gameId)).data.mode != "direct_assignment"
        );
    }

    function crewBidPayload() {
      return request.resource.data.bidderType == "crew"
        && request.resource.data.crewId is string
        && request.resource.data.crewId.size() > 0;
    }

    function bidMatchesGameLevelPolicy(gameId) {
      return !gameLevelIsVarsity(gameId) || crewBidPayload();
    }

    function requesterIsCrewReferee(crewId) {
      return crewExists(crewId)
        && get(/databases/$(database)/documents/crews/$(crewId)).data.keys().hasAny(["refereeOfficialId"])
        && get(/databases/$(database)/documents/crews/$(crewId)).data.refereeOfficialId == request.auth.uid;
    }

    function crewBidSubmittedByMember() {
      return request.resource.data.bidderType != "crew"
        || (
          request.resource.data.crewId is string
          && request.resource.data.crewId.size() > 0
          && requesterIsCrewReferee(request.resource.data.crewId)
        );
    }

    function crewPositionMapIsValid(memberPositions, allowedMemberUids) {
      return memberPositions is map
        && memberPositions.keys().hasOnly(allowedMemberUids)
        && memberPositions.values().hasOnly([
          "R",
          "U",
          "C",
          "H",
          "L",
          "S",
          "F",
          "B",
          "RO",
          "RC",
          "ALT"
        ]);
    }

    function crewRefereeFieldMatchesPositions(data) {
      return !data.keys().hasAny(["refereeOfficialId"])
        || (
          data.refereeOfficialId is string
          && data.refereeOfficialId.size() > 0
          && data.keys().hasAny(["memberUids"])
          && data.memberUids.hasAny([data.refereeOfficialId])
          && data.keys().hasAny(["memberPositions"])
          && data.memberPositions is map
          && data.memberPositions.keys().hasAny([data.refereeOfficialId])
          && data.memberPositions[data.refereeOfficialId] == "R"
        );
    }

    function creatorCrewUpdatePayloadIsValid() {
      return resource.data.createdByUid == request.auth.uid
        && crewRefereeFieldMatchesPositions(request.resource.data)
        && (
          !request.resource.data.diff(resource.data).affectedKeys().hasAny(["memberPositions", "refereeOfficialId"])
          || crewPositionMapIsValid(
            request.resource.data.memberPositions,
            request.resource.data.memberUids
          )
        );
    }

    function crewChiefCanUpdatePositionsOnly(crewId) {
      return requesterIsCrewChief(crewId)
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(["memberPositions", "refereeOfficialId"])
        && crewPositionMapIsValid(
          request.resource.data.memberPositions,
          resource.data.memberUids
        )
        && crewRefereeFieldMatchesPositions(request.resource.data);
    }

    function anonymousRatingPayload() {
      return !request.resource.data.keys().hasAny(["ratedByName", "targetName"]);
    }

    function participantRatingPayload() {
      return canManageGames()
        && request.resource.data.ratedByUid == request.auth.uid
        && (request.resource.data.ratedByRole == "assignor" || request.resource.data.ratedByRole == "school")
        && ownsGame(request.resource.data.gameId)
        && request.resource.data.targetType in ["official", "crew"];
    }

    function officialSchoolVenueRatingPayload() {
      return hasRole("official")
        && request.resource.data.ratedByUid == request.auth.uid
        && request.resource.data.ratedByRole == "official"
        && gameExists(request.resource.data.gameId)
        && request.resource.data.targetType in ["school", "venue"];
    }

    match /userProfiles/{uid} {
      allow read: if signedIn();
      allow create, update: if signedIn() && request.auth.uid == uid;
      allow delete: if false;
    }

    match /crews/{crewId} {
      allow read: if signedIn();

      allow create: if (hasRole("official") || hasRole("assignor") || hasRole("school"))
        && request.resource.data.createdByUid == request.auth.uid
        && request.resource.data.crewChiefUid == request.auth.uid
        && request.resource.data.crewChiefName is string
        && (!request.resource.data.keys().hasAny(["memberPositions"]) || crewPositionMapIsValid(
          request.resource.data.memberPositions,
          request.resource.data.memberUids
        ))
        && crewRefereeFieldMatchesPositions(request.resource.data)
        && (
          request.resource.data.createdByRole == "official" ||
          request.resource.data.createdByRole == "assignor" ||
          request.resource.data.createdByRole == "school"
        )
        && request.resource.data.memberUids.size() >= 1
        && request.resource.data.memberUids.size() <= 15;

      allow update: if signedIn()
        && (
          creatorCrewUpdatePayloadIsValid()
          || crewChiefCanUpdatePositionsOnly(crewId)
        );

      allow delete: if signedIn()
        && resource.data.createdByUid == request.auth.uid;
    }

    match /games/{gameId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /bids/{bidId} {
      allow read: if signedIn();
      allow create, update, delete: if false;
    }

    match /ratings/{ratingId} {
      allow read: if signedIn();

      allow create: if (participantRatingPayload() || officialSchoolVenueRatingPayload())
        && anonymousRatingPayload()
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;

      allow update: if (participantRatingPayload() || officialSchoolVenueRatingPayload())
        && resource.data.ratedByUid == request.auth.uid
        && request.resource.data.ratedByUid == resource.data.ratedByUid
        && request.resource.data.gameId == resource.data.gameId
        && request.resource.data.targetId == resource.data.targetId
        && request.resource.data.targetType == resource.data.targetType
        && anonymousRatingPayload()
        && request.resource.data.stars is int
        && request.resource.data.stars >= 1
        && request.resource.data.stars <= 5;

      allow delete: if false;
    }

    match /evaluations/{evaluationId} {
      allow read: if signedIn();

      allow create: if canEvaluateGames()
        && gameExists(request.resource.data.gameId)
        && request.resource.data.evaluatorUid == request.auth.uid
        && request.resource.data.overallScore is int
        && request.resource.data.overallScore >= 1
        && request.resource.data.overallScore <= 5;

      allow update: if canEvaluateGames()
        && resource.data.evaluatorUid == request.auth.uid
        && request.resource.data.evaluatorUid == resource.data.evaluatorUid
        && request.resource.data.gameId == resource.data.gameId
        && request.resource.data.overallScore is int
        && request.resource.data.overallScore >= 1
        && request.resource.data.overallScore <= 5;

      allow delete: if false;
    }
  }
}
