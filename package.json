{
  "name": "officiating-marketplace",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "seed:pittsburgh": "node scripts/seedPittsburghMarketplaceGames.mjs",
    "test": "npm run test:app && npm run test:weekly",
    "test:app": "node scripts/run-app-tests.mjs",
    "test:weekly": "node --test scripts/weekly-product-update/tests/*.test.mjs",
    "ci": "npm run test && npm run build && node --check functions/index.js",
    "weekly-product-update:example": "node scripts/weekly-product-update/generate-example.mjs",
    "weekly-product-update:dry-run": "node scripts/weekly-product-update/index.mjs"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "firebase": "^12.9.0",
    "lucide-react": "^0.577.0",
    "nodemailer": "^8.0.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10"
  }
}
